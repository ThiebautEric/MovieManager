{
  // Déploiement Cloudflare Workers (static assets) : le build Flutter web est
  // servi tel quel. Build command : sh cloudflare_build.sh ;
  // deploy command : npx wrangler deploy.
  // Le "name" doit correspondre au nom du Worker dans le dashboard.
  "name": "theyellowframe",
  "compatibility_date": "2026-07-17",
  "assets": {
    "directory": "./build/web",
    "not_found_handling": "single-page-application"
  }
}
